APP_NAME="ABU Giving"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------
# Mail — use "log" driver locally so emails are written to storage/logs
# ---------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@abu-endowment.cloud"
MAIL_FROM_NAME="ABU Giving"

# ---------------------------------------------------------------
# Paystack — get keys from https://dashboard.paystack.com/#/settings/developer
# Use TEST keys locally (sk_test_... / pk_test_...)
# ---------------------------------------------------------------
PAYSTACK_PUBLIC_KEY=pk_test_
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_WEBHOOK_SECRET=

# ---------------------------------------------------------------
# Squad — get keys from https://dashboard.squadco.com
# Use sandbox keys locally
# ---------------------------------------------------------------
SQUAD_SECRET_KEY=
SQUAD_API_URL=https://sandbox-api-d.squadco.com

# ---------------------------------------------------------------
# Google OAuth — get from https://console.cloud.google.com
# Same client ID used in the frontend App.js
# ---------------------------------------------------------------
GOOGLE_CLIENT_ID=470253699627-a50centdev8a3ahhq0e01oiakatu3qh4.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ---------------------------------------------------------------
# KudiSMS
# ---------------------------------------------------------------
KUDI_SMS_KEY=
KUDI_SMS_URL=https://my.kudisms.net/api/intcomposesms
SMS_VERIFICATION_ENABLED=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
